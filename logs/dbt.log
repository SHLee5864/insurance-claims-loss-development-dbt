  create view "dev"."main"."int_exposure_summary__dbt_tmp" as (
    

with exposure as (

    select
        e.policy_number,
        e.date_month,
        e.earned_exposure,
        e.earned_premium,
        p.region
    from "dev"."main"."stg_exposure" e
