[0m18:10:02.802159 [debug] [Thread-1 (]: On model.insurance_claims_loss_development_dbt.int_claim_base: /* {"app": "dbt", "dbt_version": "1.11.6", "profile_name": "insurance_claims_loss_development_dbt", "target_name": "dev", "node_id": "model.insurance_claims_loss_development_dbt.int_claim_base"} */

  
  create view "dev"."main"."int_claim_base__dbt_tmp" as (
    

with claims as (

    select
        c.claim_id,
        c.policy_number,
        c.accident_date,
        c.reported_date,
        extract(year from c.accident_date)   as accident_year,
        date_trunc('month', c.accident_date) as accident_month,
        c.loss_type,
        c.claimant_age,
        c.claim_key
    from "dev"."main"."stg_claims" as c

),

policy_enriched as (

    select
        cl.*,
        p.region as policy_region
    from claims cl
    left join "dev"."main"."stg_policy" as p
        on cl.policy_number = p.policy_number

),

calendar_flags as (
    select
        date_month,
        is_covid_wave,
        is_covid_lockdown,
        is_weather_event,
        travel_boom
    from "dev"."main"."stg_calendar"
),

final as (

    select
        p.claim_id,
        p.claim_key,
        p.policy_number,
        p.accident_date,
        p.reported_date,
        p.accident_year,
        p.accident_month,
        p.loss_type,
        p.claimant_age,

        -- region은 policy 기준으로만 유지
        p.policy_region as region,

        -- 사고월 기준 환경 플래그
        cf.is_covid_wave       as covid_wave_flag,
        cf.is_covid_lockdown   as covid_lockdown_flag,
        cf.is_weather_event    as weather_event_flag,
        cf.travel_boom         as travel_boom_flag

    from policy_enriched p
    left join calendar_flags cf
        on p.accident_month = cf.date_month

)

select *
from final
  );

