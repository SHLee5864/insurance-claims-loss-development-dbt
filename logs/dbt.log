  create view "dev"."main"."int_exposure_summary__dbt_tmp" as (
    

with exposure as (

    select
        policy_number,
        region,
        date_month,
        earned_exposure,
        earned_premium
    from "dev"."main"."stg_exposure"

),

with_ay as (

